rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return signedIn() ? userDoc().data.role : null;
    }

    function isRole(role) {
      return signedIn() && userRole() == role;
    }

    function isAnyAdminRole() {
      return signedIn() && userRole() in ['ae', 'aee', 'ee'];
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /complaints/{complaintId} {
      allow read: if signedIn();
      allow create, update: if isAnyAdminRole();
      allow delete: if isRole('ee');
    }

    match /field_workers/{workerId} {
      allow read: if signedIn();
      allow write: if isRole('ae') || isRole('ee');
    }
  }
}
